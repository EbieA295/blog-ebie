---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = 'Ebie Aryansya | Developer Portfolio', 
	description = 'Mahasiswa Informatika yang fokus pada web development, UI modern, dan teknologi.' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-background text-foreground flex flex-col min-h-screen selection:bg-primary/30 selection:text-white">
		<Navbar />
		<main class="flex-grow w-full max-w-5xl mx-auto px-6 pt-28 pb-16">
			<slot />
		</main>
		<Footer />
	</body>
</html>
