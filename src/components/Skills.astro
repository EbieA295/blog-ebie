---
const skills = [
  {
    category: "Frontend",
    items: ["HTML", "CSS", "JavaScript", "TypeScript", "Astro", "Tailwind CSS", "React"]
  },
  {
    category: "Backend",
    items: ["PHP", "Laravel", "Node.js"]
  },
  {
    category: "Database",
    items: ["MySQL", "PostgreSQL"]
  },
  {
    category: "Tools & Others",
    items: ["Git", "GitHub", "Figma", "VS Code"]
  }
];
---

<section class="py-20 border-t border-border">
  <div class="mb-12">
    <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">Tech Stack & Skills</h2>
    <p class="text-gray max-w-2xl">
      Teknologi dan tools yang biasa saya gunakan untuk membangun aplikasi web modern.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {skills.map(skillGroup => (
      <div class="p-6 rounded-3xl bg-surface border border-border hover:border-primary/30 shadow-[0_10px_30px_rgba(0,0,0,0.03)] hover:shadow-[0_10px_30px_rgba(255,122,0,0.08)] transition-all duration-300 hover:-translate-y-1">
        <h3 class="text-xl font-bold text-foreground mb-4">{skillGroup.category}</h3>
        <div class="flex flex-wrap gap-2">
          {skillGroup.items.map(item => (
            <span class="px-3 py-1.5 bg-background text-foreground text-sm font-medium rounded-lg border border-border hover:border-primary hover:text-primary transition-colors cursor-default">
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
