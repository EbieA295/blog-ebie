---
const currentYear = new Date().getFullYear();
---

<footer class="mt-20 border-t border-border py-10">
  <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex flex-col items-center md:items-start">
      <p class="text-sm font-medium text-foreground">
        &copy; {currentYear} Ebie Aryansya.
      </p>
      <p class="text-xs text-gray mt-1">
        Built with Astro & Tailwind CSS
      </p>
    </div>
    
    <div class="flex items-center gap-6">
      <a href="https://github.com/ebie" target="_blank" rel="noopener noreferrer" class="text-gray hover:text-primary transition-colors">
        GitHub
      </a>
      <a href="https://instagram.com/ebie" target="_blank" rel="noopener noreferrer" class="text-gray hover:text-primary transition-colors">
        Instagram
      </a>
      <a href="mailto:email@example.com" class="text-gray hover:text-primary transition-colors">
        Email
      </a>
    </div>
  </div>
</footer>
