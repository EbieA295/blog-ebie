---
import { Image } from 'astro:assets';
import fotoEbie from '../assets/fotome.jpeg'; // 💡 Pastikan foto kamu ditaruh di folder src/assets/ dengan nama ebie.png (atau sesuaikan ekstensinya)
---

<section class="min-h-[80vh] flex flex-col md:flex-row items-center justify-between gap-12 py-10">
  <div class="flex-1 space-y-6">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-soft text-primary-dark text-sm font-medium">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      Available for work
    </div>
    
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-foreground leading-tight">
      Halo, saya <span class="text-primary">Ebie.</span>
    </h1>
    
    <p class="text-lg md:text-xl text-gray max-w-lg leading-relaxed">
      Mahasiswa Informatika yang fokus pada web development, 
      UI modern, dan teknologi.
    </p>
    
    <div class="flex flex-wrap items-center gap-4 pt-4">
      <a href="/projects" class="px-6 py-3 rounded-xl bg-primary text-white font-medium hover:bg-primary-dark transition-all hover:shadow-lg hover:shadow-primary/30 hover:-translate-y-1">
        Lihat Project
      </a>
      <a href="/blog" class="px-6 py-3 rounded-xl bg-surface border border-border text-foreground font-medium hover:border-primary hover:text-primary transition-all hover:shadow-sm">
        Baca Blog
      </a>
    </div>
  </div>
  
  <div class="flex-1 relative flex justify-center items-center w-full max-w-md">
    <div class="absolute inset-0 bg-primary/20 blur-[80px] rounded-full mix-blend-multiply"></div>
    <div class="absolute inset-4 bg-primary-soft blur-2xl rounded-full"></div>
    
    <div class="relative w-64 h-64 md:w-80 md:h-80 rounded-4xl bg-linear-to-tr from-primary to-primary-soft p-1 rotate-3 hover:rotate-0 transition-all duration-500 shadow-xl overflow-hidden group">
      <div class="w-full h-full rounded-[1.8rem] bg-surface overflow-hidden">
        
        <Image 
          src={fotoEbie} 
          alt="Foto Ebie" 
          loading="eager"
          class="w-full h-full object-cover object-center -rotate-3 group-hover:rotate-0 scale-110 group-hover:scale-105 transition-all duration-500"
        />

      </div>
    </div>
  </div>
</section>