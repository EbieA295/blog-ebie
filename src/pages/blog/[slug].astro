---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug || post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
let Content;
try {
  // Astro 5+ way
  const { render } = await import('astro:content');
  const rendered = await render(post);
  Content = rendered.Content;
} catch (e) {
  // Fallback for Astro < 5
  const rendered = await post.render();
  Content = rendered.Content;
}
---

<BaseLayout title={`${post.data.title} - Blog Ebie`} description={post.data.description}>
	<div class="max-w-3xl mx-auto">
		<div class="mb-8">
			<a href="/" class="text-gray hover:text-primary transition-colors text-sm font-bold uppercase tracking-widest">&larr; Kembali</a>
		</div>
		
		<article class="bg-surface border border-border p-8 md:p-10 rounded-[32px] shadow-[0_10px_30px_rgba(0,0,0,0.1)]">
			<header class="mb-8 border-b border-border pb-8">
				<h1 class="text-3xl md:text-5xl font-black text-foreground mb-4 tracking-tight">{post.data.title}</h1>
				<p class="text-gray text-lg mb-6 leading-relaxed">{post.data.description}</p>
				<div class="flex items-center text-xs gap-3">
					<span class="bg-primary/10 text-primary px-3 py-1.5 rounded-md font-bold tracking-widest border border-primary/20">{post.data.author}</span>
					<span class="text-gray font-mono bg-background px-3 py-1.5 rounded-md border border-border">
            {post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('id-ID', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						}) : 'Terbaru'}
          </span>
				</div>
			</header>
			
			<div class="prose prose-invert prose-orange max-w-none text-gray prose-headings:text-foreground prose-a:text-primary hover:prose-a:text-primary-dark">
				<Content />
			</div>
		</article>
	</div>
</BaseLayout>
