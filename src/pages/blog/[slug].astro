---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug || post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
let Content;
try {
  // Astro 5+ way
  const { render } = await import('astro:content');
  const rendered = await render(post);
  Content = rendered.Content;
} catch (e) {
  // Fallback for Astro < 5
  const rendered = await post.render();
  Content = rendered.Content;
}
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{post.data.title} - Blog Ebie</title>
	</head>
	<body class="bg-slate-950 text-white font-sans selection:bg-orange-500 selection:text-white">
		<main class="min-h-screen p-6 max-w-2xl mx-auto">
			<div class="mb-8">
				<a href="/" class="text-slate-400 hover:text-orange-500 transition-colors text-sm font-bold uppercase tracking-widest">&larr; Kembali</a>
			</div>
			
			<article class="bg-slate-900 border border-slate-800 p-8 md:p-10 rounded-3xl shadow-2xl">
				<header class="mb-8 border-b border-slate-800 pb-8">
					<h1 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">{post.data.title}</h1>
					<p class="text-slate-400 text-sm mb-6 leading-relaxed">{post.data.description}</p>
					<div class="flex items-center text-xs gap-3">
						<span class="bg-slate-800 text-orange-400 px-3 py-1.5 rounded-md font-bold tracking-widest border border-slate-700">{post.data.author}</span>
						<span class="text-slate-500 font-mono bg-slate-950 px-3 py-1.5 rounded-md border border-slate-800">{post.data.pubDate}</span>
					</div>
				</header>
				
				<div class="prose prose-invert prose-orange max-w-none text-slate-300">
					<Content />
				</div>
			</article>
		</main>
	</body>
</html>
