---

import '../styles/global.css'
import { getCollection } from 'astro:content';


const nama = "Ebie Aryansya";
const prodi = "Informatika UNP";
const posts = await getCollection('blog');

---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Blog {nama}</title>
	</head>
	<body class="bg-slate-950 text-white font-sans selection:bg-orange-500 selection:text-white">
		<main class="min-h-screen flex items-center justify-center p-6">
			<div class="max-w-md w-full bg-slate-900 border border-slate-800 p-8 rounded-3xl shadow-2xl transform hover:scale-105 transition-all duration-300">
				<!-- Header -->
				<div class="flex items-center space-x-4 mb-6">
					<div class="w-12 h-12 bg-orange-600 rounded-full flex items-center justify-center font-bold text-xl">
						{nama.charAt(0)}
					</div>
					<div>
						<h1 class="text-2xl font-black tracking-tight text-white uppercase">{nama}</h1>
						<p class="text-orange-500 text-xs font-bold tracking-widest">{prodi}</p>
					</div>
				</div>

				<!-- Content -->
				<div class="space-y-4">
					<p class="text-slate-400 leading-relaxed">
						Selamat datang di blog pertama saya! Sedang belajar <span class="text-white font-mono bg-slate-800 px-1">Astro</span> dan <span class="text-white font-mono bg-slate-800 px-1">Tailwind CSS</span> untuk portofolio kedepannya.
					</p>
					
					<div class="pt-4 flex flex-wrap gap-2">
						<span class="bg-slate-800 text-slate-300 text-[10px] px-2 py-1 rounded-md border border-slate-700">Asus TUF A16</span>
						<span class="bg-slate-800 text-slate-300 text-[10px] px-2 py-1 rounded-md border border-slate-700">Windows 11</span>
						<span class="bg-slate-800 text-slate-300 text-[10px] px-2 py-1 rounded-md border border-slate-700">Semester 2</span>
					</div>
				</div>

				<!-- Footer -->
				<div class="mt-8 pt-6 border-t border-slate-800 text-center">
					<button class="bg-white text-black font-bold py-2 px-6 rounded-full text-sm hover:bg-orange-500 hover:text-white transition-colors uppercase tracking-widest">
						Baca Artikel
					</button>
				</div>

					<div class="mt-6 space-y-2 text-left">
					<h3 class="text-xs font-bold text-slate-500 uppercase tracking-widest">Artikel Terbaru</h3>
					{posts.map((post : any) => (
							<a href={`/blog/${post.id}`} class="block p-3 rounded-lg bg-slate-800 hover:bg-slate-700 transition-colors border border-slate-700">
							<h4 class="text-sm font-semibold">{post.data.title}</h4>
							<p class="text-xs text-slate-400">{post.data.description}</p>
							</a>
					))}
					</div>
			</div>
		</main>
	</body>
</html>